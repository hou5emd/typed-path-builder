{
  "name": "typed-path-builder",
  "version": "0.5.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "description": "This Build type-safe paths from a simple config object.",
  "repository": {
    "url": "https://github.com/hou5emd/typed-path-builder"
  },
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write '**/*.{js,ts}'",
    "typecheck": "tsc --noEmit",
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "rstest run"
  },
  "keywords": [
    "typed",
    "react-router",
    "typed-url"
  ],
  "author": "https://github.com/hou5emd",
  "license": "MIT",
  "devDependencies": {
    "@rsbuild/plugin-type-check": "^1.3.4",
    "@rslib/core": "^0.20.3",
    "@rstest/adapter-rslib": "^0.2.1",
    "@rstest/core": "^0.9.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,ts}": "prettier --write"
  }
}
